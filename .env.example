PORT=4000
CLIENT_ORIGIN=http://localhost:5173
SOCKET_PING_INTERVAL_MS=25000
SOCKET_PING_TIMEOUT_MS=30000
SOCKET_CONNECT_TIMEOUT_MS=20000
NODE_ENV=development
ADMIN_KEY=change-me-for-local-admin
# Firebase-authenticated admin emails. Keep backend-only and comma separate multiple entries.
ADMIN_EMAILS=
# Optional backend-only verified email allowlist for support/owner full product access.
FULL_ACCESS_EMAILS=
# Local/dev ADMIN_KEY fallback is on by default. Production fallback needs this explicit opt-in.
ALLOW_ADMIN_KEY_IN_PRODUCTION=false
TRUST_PROXY=true
LOG_LEVEL=info
ERROR_REPORTING_DSN=
LAUNCH_MODE=dev
MAINTENANCE_MODE=false
SIGNUPS_ENABLED=true
GUEST_CHAT_ENABLED=true
COMMUNITIES_ENABLED=true
STORE_ENABLED=true
PERSISTENCE_ENABLED=false
DATA_RETENTION_DAYS=30

# Optional Redis scaling/cache/rate-limit layer. Safe memory fallback when disabled.
REDIS_ENABLED=false
REDIS_URL=
REDIS_PREFIX=nexuschat

# Optional Firebase Cloud Messaging push. Safe off by default.
FCM_ENABLED=false

# Single-instance safe background jobs for temp cleanup, events, scheduled announcements, and retention.
JOBS_ENABLED=true
JOB_INTERVAL_MS=60000

# Phase 6 billing defaults to disabled. Razorpay secrets are backend-only.
BILLING_ENABLED=false
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CHECKOUT_CONFIG_ID=

# Firebase Admin backend credentials. Use one style only and never expose these to Vite.
# Optional backend token verification fallback when Firebase Admin is absent.
FIREBASE_WEB_API_KEY=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Public Firebase web config for optional Google login on the Vite frontend.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_VAPID_KEY=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_GA_MEASUREMENT_ID=
VITE_ENABLE_ANALYTICS=false
VITE_SUPPORT_EMAIL=
