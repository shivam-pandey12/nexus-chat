{
  "name": "nexus-chat",
  "version": "1.0.0",
  "private": true,
  "description": "Nexus Chat room-based real-time social chat app for MH Horizon.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,client -c yellow,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch server/index.js --dev",
    "dev:client": "vite --host 0.0.0.0",
    "build": "vite build",
    "start": "node server/index.js",
    "check": "npm run build"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^5.1.2",
    "compression": "^1.8.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.10.0",
    "helmet": "^8.1.0",
    "razorpay": "^2.9.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "redis": "^5.12.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tailwindcss": "^4.3.0",
    "vite": "^7.3.1"
  }
}
